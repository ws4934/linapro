# =============================================================================
# Editors / IDEs
# =============================================================================
.buildpath
.project
.settings/
.idea/
.vscode/
.hgignore.swp
*.swp
*.orig

# =============================================================================
# OS
# =============================================================================
**/.DS_Store

# =============================================================================
# External / nested repos (not tracked as submodules)
# =============================================================================
/linapro-site/

# =============================================================================
# Temp / scratch
# =============================================================================
.tmp/
temp/
assets/
!.github/assets/
!.github/assets/linapro-logo.webp

# =============================================================================
# Agent / AI tooling local config
# =============================================================================
.aiprompt.zh.md
.codex/config.toml
.github/codex/*
!.github/codex/
!.github/codex/config.template.toml
!.github/codex/auth.template.json
.github/codex/auth.json

# Vendored skill sources (managed externally)
.agents/skills/goframe-v2/

# =============================================================================
# Backend (apps/lina-core)
# =============================================================================
apps/lina-core/temp/
apps/lina-core/internal/packed/manifest/**
!apps/lina-core/internal/packed/manifest/.gitkeep
!apps/lina-core/internal/packed/manifest/apidoc/
!apps/lina-core/internal/packed/manifest/apidoc/i18n/
!apps/lina-core/internal/packed/manifest/apidoc/i18n/*.json

# =============================================================================
# Frontend
# =============================================================================
**/node_modules/
**/dist/
**/dist.zip
**/.turbo/

# =============================================================================
# Testing
# =============================================================================
.playwright-cli/
.playwright-mcp/
playwright-report/
test-results/
*.tar.zst

# =============================================================================
# Build artifacts
# =============================================================================
*.exe
*.test
*.out
apps/lina-plugins/*/temp/
/apps/lina-plugins/.linapro-plugins.lock.yaml

# =============================================================================
# Agent private project directories
# Managed locally by `make agents.skills.link` / `make agents.prompts.link`.
# Sources live under .agents/skills and .agents/prompts; per-tool symlinks
# created at the repo root must not be committed. Already-tracked symlinks
# (e.g. .claude/skills, .claude/commands) keep working because .gitignore
# does not affect files already in the index.
# =============================================================================
/.adal/
/.aider-desk/
/.augment/
/.bob/
/.claude/
/.codeartsdoer/
/.codebuddy/
/.codemaker/
/.codestudio/
/.codex/
/.commandcode/
/.continue/
/.cortex/
/.crush/
/.cursor/
/.devin/
/.factory/
/.forge/
/.gemini/
/.goose/
/.hermes/
/.iflow/
/.junie/
/.kilocode/
/.kiro/
/.kode/
/.mcpjam/
/.mux/
/.neovate/
/.openhands/
/.pi/
/.pochi/
/.qoder/
/.qwen/
/.roo/
/.rovodev/
/.tabnine/
/.trae/
/.vibe/
/.windsurf/
/.zencoder/

# rootCollision agent (openclaw) — only created with explicit AGENT=openclaw FORCE=1.
# Ignored to keep an opt-in symlink from polluting the repo root if a user enables it.
/skills
